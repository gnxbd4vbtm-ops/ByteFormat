{
  "scopeName": "source.byteformat",
  "patterns": [
    { "include": "#comments" },
    { "include": "#multilineString" },
    { "include": "#string" },
    { "include": "#enum" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#keyValue" },
    { "include": "#brackets" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.byteformat"
        }
      ]
    },

    "keyValue": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*=)",
          "name": "variable.other.property.byteformat"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.byteformat"
        }
      ]
    },

    "string": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.byteformat",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.byteformat"
            }
          ]
        }
      ]
    },

    "multilineString": {
      "patterns": [
        {
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.multi.byteformat"
        }
      ]
    },

    "enum": {
      "patterns": [
        {
          "match": "enum:[A-Z_]+",
          "name": "constant.language.enum.byteformat"
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.byteformat"
        }
      ]
    },

    "boolean": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.byteformat"
        }
      ]
    },

    "brackets": {
      "patterns": [
        {
          "match": "[\\{\\}\\[\\]]",
          "name": "punctuation.section.byteformat"
        }
      ]
    }
  }
}