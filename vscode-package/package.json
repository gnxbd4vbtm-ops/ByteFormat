{
  "name": "byteformat-extension",
  "displayName": "ByteFormat",
  "version": "0.0.1",
  "publisher": "Byte Blast",
  "engines": {
    "vscode": "^1.80.0"
  },
  "contributes": {
    "iconThemes": [
      {
        "id": "byteformat-icons",
        "label": "ByteFormat Icons",
        "path": "./icons.json"
      }
    ],
    "languages": [
      {
        "id": "byteformat",
        "aliases": ["ByteFormat"],
        "extensions": [".byte"]
      }
    ],
    "grammars": [
      {
        "language": "byteformat",
        "scopeName": "source.byteformat",
        "path": "./syntaxes/byteformat.tmLanguage.json"
      }
    ]
  }
}