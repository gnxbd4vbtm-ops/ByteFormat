{
  "scopeName": "source.byte",
  "patterns": [
    { "include": "#comments" },
    { "include": "#tripleStrings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#keys" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.byte",
          "match": "#.*$"
        }
      ]
    },
    "tripleStrings": {
      "patterns": [
        {
          "name": "string.quoted.triple.byte",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": []
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.byte",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.byte",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.byte",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.byte",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "keys": {
      "patterns": [
        {
          "name": "variable.other.property.byte",
          "match": "\"[a-zA-Z0-9_]+\"(?=\\s*:)"
        }
      ]
    }
  }
}