{
  "name": "byteformat",
  "displayName": "Byte Format",
  "description": "VS Code language support for ByteFormat .byte files",
  "version": "3.0.0",
  "publisher": "gnxbd4vbtm-ops",
  "license": "MIT",
  "author": {
    "name": "gnxbd4vbtm-ops",
    "email": "gnxbd4vbtm@privaterelay.appleid.com",
    "url": "https://byteblast.online"
  },
  "icon": "icons/byte.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:byte"
  ],
  "contributes": {
    "languages": [
      {
        "id": "byte",
        "aliases": ["ByteFormat", "byte"],
        "extensions": [".byte"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "byte",
        "scopeName": "source.byte",
        "path": "./syntaxes/byte.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "ByteFormat Syntax Colors",
        "uiTheme": "vs-dark",
        "path": "./themes/byteformat-color-theme.json"
      }
    ]
  }
}